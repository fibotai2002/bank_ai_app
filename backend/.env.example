# ── Majburiy o'zgaruvchilar ────────────────────────────────────────────────────

# Gemini AI API kaliti (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT token uchun maxfiy kalit — production da murakkab kalit ishlating!
# Misol: openssl rand -hex 32
SECRET_KEY=your-very-secret-key-change-this-in-production

# ── Ma'lumotlar bazasi ─────────────────────────────────────────────────────────

# Development uchun SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./bank_ai.db

# Production uchun PostgreSQL (Render, Neon, Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS sozlamalari ───────────────────────────────────────────────────────────

# Development uchun barcha domenga ruxsat
CORS_ORIGINS=*

# Production uchun aniq domenlar (vergul bilan ajrating)
# CORS_ORIGINS=https://your-app.com,https://www.your-app.com

# ── Muhit ──────────────────────────────────────────────────────────────────────

# production yoki development
# production da /docs va /redoc o'chiriladi
ENVIRONMENT=development

# ── Ixtiyoriy ─────────────────────────────────────────────────────────────────

# OpenAI API kaliti (agar ishlatilsa)
# OPENAI_API_KEY=sk-your-openai-key-here
